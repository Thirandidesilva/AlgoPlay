<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <top>
        <HBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <Label text="Session:" />
                <ComboBox fx:id="sessionComboBox" prefWidth="300.0" promptText="Select Session" />
                <Button fx:id="refreshButton" mnemonicParsing="false" text="Refresh" />
                <Button fx:id="exportCsvButton" mnemonicParsing="false" text="Export to CSV" />
            </children>
        </HBox>
    </top>
    <center>
        <VBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" />
            </padding>
            <children>
                <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="uuidCol" text="Session UUID" />
                        <TableColumn fx:id="createdCol" text="Created At" />
                        <TableColumn fx:id="cityCountCol" text="Cities" />
                        <TableColumn fx:id="sourceCol" text="Source" />
                        <TableColumn fx:id="pathLengthCol" text="Path Length" />
                        <TableColumn fx:id="execTimeCol" text="Execution Time (ms)" />
                        <TableColumn fx:id="cityOrderCol" prefWidth="200.0" text="City Order" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </center>
    <bottom>
        <HBox spacing="10.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
            <children>
                <BarChart fx:id="executionTimeChart" title="Execution Time Comparison" legendVisible="false" HBox.hgrow="ALWAYS">
                    <xAxis>
                        <CategoryAxis label="Source" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Execution Time (ms)" />
                    </yAxis>
                </BarChart>
                <BarChart fx:id="pathLengthChart" title="Path Length Comparison" legendVisible="false" HBox.hgrow="ALWAYS">
                    <xAxis>
                        <CategoryAxis label="Source" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Path Length" />
                    </yAxis>
                </BarChart>
            </children>
        </HBox>
    </bottom>
</BorderPane>