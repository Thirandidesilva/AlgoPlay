<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.algoplay.controllers.HanoiDataViewController">
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Tower of Hanoi Data View" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                <Button fx:id="backToGameButton" text="← Back to Game" onAction="#backToGame"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Refresh Data" onAction="#refreshData"/>
                <Button text="Export to CSV" onAction="#exportToCSV"/>
            </HBox>
        </VBox>
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Label text="Tower of Hanoi Data View" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="Refresh Data" onAction="#refreshData"/>
                <Button text="Export to CSV" onAction="#exportToCSV"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="dataTable">
            <columns>
                <TableColumn fx:id="usernameColumn" text="Username" prefWidth="100"/>
                <TableColumn fx:id="gameNameColumn" text="Game" prefWidth="100"/>
                <TableColumn fx:id="diskCountColumn" text="Disk Count" prefWidth="80"/>
                <TableColumn fx:id="moveCountColumn" text="Moves" prefWidth="80"/>
                <TableColumn fx:id="optimalMovesColumn" text="Optimal Moves" prefWidth="100"/>
                <TableColumn fx:id="isCorrectColumn" text="Solved Correctly" prefWidth="100"/>
                <TableColumn fx:id="recursiveTimeColumn" text="Recursive Time (ms)" prefWidth="120"/>
                <TableColumn fx:id="iterativeTimeColumn" text="Iterative Time (ms)" prefWidth="120"/>
                <TableColumn fx:id="fourPegTimeColumn" text="Four Peg Time (ms)" prefWidth="120"/>
                <TableColumn fx:id="moveSequenceColumn" text="Move Sequence" prefWidth="200"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT" >
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
            </padding>
            <Label fx:id="statusLabel" text="Ready"/>
        </HBox>
    </bottom>
</BorderPane>