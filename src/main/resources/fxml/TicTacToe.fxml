<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane stylesheets="@/css/tictactoe.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.algoplay.controllers.TicTacToeController">
    <center>
        <GridPane fx:id="gameGrid" alignment="CENTER" hgap="5.0" vgap="5.0" BorderPane.alignment="CENTER" visible="false">
            <BorderPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </BorderPane.margin>
        </GridPane>
    </center>
    <top>
        <VBox alignment="CENTER" spacing="5.0" BorderPane.alignment="CENTER">
            <children>
                <Label styleClass="title-label" text="5x5 Tic Tac Toe">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <VBox fx:id="setupPane" alignment="CENTER" spacing="15.0">
                    <children>
                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label text="Player Name:" />
                                <TextField fx:id="playerNameField" promptText="Enter your name" />
                            </children>
                        </HBox>
                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Label text="Difficulty:" />
                                <ComboBox fx:id="difficultyComboBox" prefWidth="150.0" promptText="Select Difficulty" />
                            </children>
                        </HBox>
                        <Button fx:id="startGameButton" mnemonicParsing="false" onAction="#startGame" styleClass="start-button" text="Start Game" />
                    </children>
                    <padding>
                        <Insets bottom="10.0" top="10.0" />
                    </padding>
                </VBox>
                <HBox fx:id="gameInfoPane" alignment="CENTER" spacing="20.0" visible="false">
                    <children>
                        <Label fx:id="playerNameLabel" text="Player: Guest">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <Label fx:id="difficultyLabel" text="Difficulty: Medium">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                    </children>
                    <VBox.margin>
                        <Insets bottom="5.0" top="5.0" />
                    </VBox.margin>
                </HBox>
                <Label fx:id="statusLabel" styleClass="status-label" text="Your turn" visible="false">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>
            </children>
            <BorderPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </BorderPane.margin>
        </VBox>
    </top>
    <bottom>
        <VBox alignment="CENTER" spacing="10.0" BorderPane.alignment="CENTER">
            <children>
                <Label fx:id="moveCountLabel" text="Player Moves: 0 | AI Moves: 0" visible="false" />
                <HBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Button fx:id="resetButton" mnemonicParsing="false" onAction="#resetGame" styleClass="action-button" text="Reset Game" />
                        <Button fx:id="mainMenuButton" mnemonicParsing="false" onAction="#backToMainMenu" styleClass="action-button" text="Back to Main Menu" />
                        <Button fx:id="dataViewButton" mnemonicParsing="false" onAction="#openDataView" styleClass="action-button" text="Data View" />
                    </children>
                </HBox>
            </children>
            <BorderPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </BorderPane.margin>
        </VBox>
    </bottom>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
</BorderPane>